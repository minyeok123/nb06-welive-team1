generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Models
// ----------------------------------------------------------------------------

model User {
  id              String         @id @default(uuid())
  profileImg      String?        @map("profile_img")
  registerId      String?        @unique @map("register_id")
  username        String         @unique
  aptId           String?        @map("apt_id")
  name            String
  email           String         @unique
  phoneNumber     String         @map("phone_number")
  password        String
  role            Role
  register_status RegisterStatus
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  // Relations
  apartment     Apartment?     @relation(fields: [aptId], references: [id])
  resident      Resident?
  comments      Comment[]
  notifications Notification[]
  register      Register?      @relation(fields: [registerId], references: [id])

  // residentRoster 테이블에서 참조하는 외래키들의 역방향 관계 (관계 이름으로 연결)
  userResidentRoster   residentRoster?  @relation("userResidentRosters")
  adminResidentRosters residentRoster[] @relation("adminResidentRosters")
  complaints           Complaint[]
  votes                Vote[]
  notices              Notice[]

  @@map("users")
}

model Register {
  id              String         @id @default(uuid())
  register_status RegisterStatus
  aptId           String?        @map("apt_id")
  username        String         @unique
  phoneNumber     String         @map("phone_number")
  name            String
  email           String         @unique
  password        String
  requestedRole   Role           @map("requested_role")
  dong            Int?
  ho              Int?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  // Relations
  user User?

  @@index([aptId, register_status])
  @@index([requestedRole, register_status])
  @@map("registers")
}

model Apartment {
  id                 String         @id @default(uuid())
  aptName            String         @map("apt_name")
  aptAddress         String         @unique @map("apt_address")
  officeNumber       String         @unique @map("office_number")
  description        String         @map("description")
  startComplexNumber Int            @map("start_complex_number")
  endComplexNumber   Int            @map("end_complex_number")
  startDongNumber    Int            @map("start_dong_number")
  endDongNumber      Int            @map("end_dong_number")
  startFloorNumber   Int            @map("start_floor_number")
  endFloorNumber     Int            @map("end_floor_number")
  startHoNumber      Int            @map("start_ho_number")
  endHoNumber        Int            @map("end_ho_number")
  aptStatus          RegisterStatus @default(PENDING)
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  deletedAt          DateTime?      @map("deleted_at")

  // Relations
  users           User[]
  boards          Board[]
  residents       Resident[]
  residentRosters residentRoster[]

  @@map("apartment")
}

model Resident {
  id           String      @id @default(uuid())
  userId       String      @unique @map("user_id")
  aptId        String      @map("apt_id")
  dong         Int
  ho           Int
  is_houseHold IsHouseHold @default(MEMBER)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  deletedAt    DateTime?   @map("deleted_at")

  // Relations
  user               User                @relation(fields: [userId], references: [id])
  apartment          Apartment           @relation(fields: [aptId], references: [id])
  voteParticipations VoteParticipation[]

  @@unique([aptId, userId])
  @@map("residents")
}

model Complaint {
  id        String    @id @default(uuid())
  boardId   String    @map("board_id")
  authorId  String    @map("author_id")
  title     String
  content   String
  status    Status
  is_public IsPublic
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  board  Board @relation(fields: [boardId], references: [id])
  author User  @relation(fields: [authorId], references: [id])

  @@index([status])
  @@map("complaints")
}

model Vote {
  id         String    @id @default(uuid())
  boardId    String    @map("board_id")
  authorId   String    @map("author_id")
  title      String
  content    String
  status     Status
  targetDong String[]  @map("target_dong")
  startDate  DateTime  @map("start_date")
  endDate    DateTime  @map("end_date")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  // Relations
  board          Board               @relation(fields: [boardId], references: [id])
  author         User                @relation(fields: [authorId], references: [id])
  options        VoteOption[]
  participations VoteParticipation[]

  @@map("votes")
}

model Notice {
  id        String         @id @default(uuid())
  boardId   String         @map("board_id")
  authorId  String         @map("author_id")
  title     String
  content   String
  startDate DateTime?      @map("start_date")
  endDate   DateTime?      @map("end_date")
  is_pinned Boolean        @map("is_pinned")
  category  NoticeCategory
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  deletedAt DateTime?      @map("deleted_at")

  // Relations
  board  Board @relation(fields: [boardId], references: [id])
  author User  @relation(fields: [authorId], references: [id])

  @@map("notices")
}

model Board {
  id        String    @id @default(uuid())
  aptId     String    @map("apt_id")
  boardType BoardType @map("board_type")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  complaint     Complaint[]
  vote          Vote[]
  notice        Notice[]
  apartment     Apartment      @relation(fields: [aptId], references: [id])
  comments      Comment[]
  notifications Notification[]

  @@index([boardType, aptId])
  @@map("boards")
}

model Comment {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  boardId   String   @map("board_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user  User  @relation(fields: [userId], references: [id])
  board Board @relation(fields: [boardId], references: [id])

  @@map("comments")
}

model VoteOption {
  id        String   @id @default(uuid())
  voteId    String   @map("vote_id")
  option    String   @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  vote           Vote                @relation(fields: [voteId], references: [id])
  participations VoteParticipation[]

  @@unique([voteId, option])
  @@map("vote_options")
}

model VoteParticipation {
  id           String   @id @default(uuid())
  residentId   String   @map("resident_id")
  voteId       String   @map("vote_id")
  voteOptionId String?  @map("vote_option_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  resident   Resident    @relation(fields: [residentId], references: [id])
  vote       Vote        @relation(fields: [voteId], references: [id])
  voteOption VoteOption? @relation(fields: [voteOptionId], references: [id])

  @@unique([residentId, voteId])
  @@map("vote_participations")
}

model Notification {
  id               String           @id @default(uuid())
  userId           String           @map("user_id")
  boardId          String           @map("board_id")
  message          String
  is_read          Boolean          @default(false)
  notificationType NotificationType @map("notification_type")
  complaintId      String?
  noticeId         String?
  voteId           String?
  notificatedAt    DateTime?        @map("notificated_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  // Relations
  user  User  @relation(fields: [userId], references: [id])
  board Board @relation(fields: [boardId], references: [id])

  @@map("notifications")
}

model residentRoster {
  id            String      @id @default(uuid())
  aptId         String      @map("apt_id")
  adminId       String      @map("admin_id")
  userId        String?     @unique @map("user_id")
  dong          Int
  ho            Int
  name          String
  phoneNumber   String      @map("phone_number")
  is_houseHold  IsHouseHold @map("is_house_hold")
  is_registered Boolean     @default(false) @map("is_registered")
  is_residence  Boolean     @default(true) @map("is_residence")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  // Relations
  apartment Apartment @relation(fields: [aptId], references: [id])
  admin     User      @relation("adminResidentRosters", fields: [adminId], references: [id])
  user      User?     @relation("userResidentRosters", fields: [userId], references: [id])
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum Status {
  PENDING
  IN_PROGRESS
  DONE
}

enum IsPublic {
  PRIVATE
  PUBLIC
}

enum RegisterStatus {
  PENDING
  APPROVED
  REJECTED
}

enum IsHouseHold {
  HOUSEHOLD
  MEMBER
}

enum BoardType {
  COMPLAINT
  VOTE
  NOTICE
}

enum NoticeCategory {
  MAINTENANCE
  EMERGENCY
  COMMUNITY
  RESIDENT_VOTE
  RESIDENT_COUNCIL
  ETC
}

enum NotificationType {
  GENERAL
  SIGNUP_REQ
  COMPLAINT_REQ
  COMPLAINT_IN_PROGRESS
  COMPLAINT_RESOLVED
  COMPLAINT_REJECTED
  NOTICE_REG
  POLL_REG
  POLL_CLOSED
  POLL_RESULT
  SYSTEM
  TEST
}
