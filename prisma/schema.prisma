model ComplaintComment {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  complaintId String    @map("complaint_id")
  content     String
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  // Relations
  user        User      @relation(fields: [userId], references: [id])
  complaint   Complaint @relation(fields: [complaintId], references: [id])

  @@map("complaint_comments")
}

model NoticeComment {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  noticeId  String    @map("notice_id")
  content   String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  // Relations
  user      User      @relation(fields: [userId], references: [id])
  notice    Notice    @relation(fields: [noticeId], references: [id])

  @@map("notice_comments")
}

model VoteOption {
  id        String   @id @default(uuid())
  voteId    String   @map("vote_id")
  option    String   @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  poll           Poll                @relation(fields: [voteId], references: [id])
  participations VoteParticipation[]

  @@unique([voteId, option])
  @@map("vote_options")
}

model VoteParticipation {
  id           String   @id @default(uuid())
  residentId   String   @map("resident_id")
  voteId       String   @map("vote_id")
  voteOptionId String?  @map("vote_option_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  resident   Resident    @relation(fields: [residentId], references: [id])
  poll       Poll        @relation(fields: [voteId], references: [id])
  voteOption VoteOption? @relation(fields: [voteOptionId], references: [id])

  @@unique([residentId, voteId])
  @@map("vote_participations")
}

model Notification {
  id               String           @id @default(uuid())
  userId           String           @map("user_id")
  boardId          String           @map("board_id")
  message          String
  is_read          Boolean          @default(false)
  notificationType NotificationType @map("notification_type")
  complaintId      String?
  noticeId         String?
  voteId           String?
  notificatedAt    DateTime?        @map("notificated_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  // Relations
  user  User  @relation(fields: [userId], references: [id])
  board Board @relation(fields: [boardId], references: [id])

  @@map("notifications")
}

model residentRoster {
  id            String      @id @default(uuid())
  aptId         String      @map("apt_id")
  adminId       String      @map("admin_id")
  userId        String?     @unique @map("user_id")
  dong          Int
  ho            Int
  name          String
  phoneNumber   String      @unique @map("phone_number")
  is_houseHold  IsHouseHold @default(MEMBER) @map("is_house_hold")
  is_registered Boolean     @default(false) @map("is_registered")
  is_residence  Boolean     @default(true) @map("is_residence")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  // Relations
  apartment Apartment @relation(fields: [aptId], references: [id])
  admin     User      @relation("adminResidentRosters", fields: [adminId], references: [id])
  user      User?     @relation("userResidentRosters", fields: [userId], references: [id])
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum Status {
  PENDING
  IN_PROGRESS
  DONE
}

enum IsPublic {
  PRIVATE
  PUBLIC
}

enum RegisterStatus {
  PENDING
  APPROVED
  REJECTED
}

enum IsHouseHold {
  HOUSEHOLDER
  MEMBER
}

enum BoardType {
  COMPLAINT
  VOTE
  NOTICE
}

enum NoticeCategory {
  MAINTENANCE
  EMERGENCY
  COMMUNITY
  RESIDENT_VOTE
  RESIDENT_COUNCIL
  ETC
}

enum NotificationType {
  GENERAL
  SIGNUP_REQ
  COMPLAINT_REQ
  COMPLAINT_IN_PROGRESS
  COMPLAINT_RESOLVED
  COMPLAINT_REJECTED
  NOTICE_REG
  POLL_REG
  POLL_CLOSED
  POLL_RESULT
  SYSTEM
  TEST
}
