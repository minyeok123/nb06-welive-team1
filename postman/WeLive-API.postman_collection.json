{
  "info": {
    "name": "WeLive API - Notice & Comment",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "boardId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "로그인 (먼저 실행)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 로그인 성공 시 응답에서 boardIds 저장",
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.boardIds?.NOTICE) {",
                  "        pm.collectionVariables.set('boardId', json.boardIds.NOTICE);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testnotice\",\n  \"password\": \"test1234\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "2. Notice",
      "item": [
        {
          "name": "공지 목록 조회",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/notices?page=1&limit=10"
          }
        },
        {
          "name": "공지 상세 조회",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/notices/:noticeId",
            "urlPath": [{"key": "noticeId", "value": "여기에_noticeId_입력"}]
          }
        },
        {
          "name": "공지 등록",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"boardId\": \"{{boardId}}\",\n  \"category\": \"COMMUNITY\",\n  \"title\": \"테스트 공지 제목\",\n  \"content\": \"테스트 공지 내용입니다.\",\n  \"isPinned\": false\n}"
            },
            "url": "{{baseUrl}}/api/notices"
          }
        },
        {
          "name": "공지 수정",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"boardId\": \"{{boardId}}\",\n  \"title\": \"수정된 제목\",\n  \"content\": \"수정된 내용\",\n  \"userId\": \"여기에_userId_입력\"\n}"
            },
            "url": "{{baseUrl}}/api/notices/:noticeId",
            "urlPath": [{"key": "noticeId", "value": "여기에_noticeId_입력"}]
          }
        },
        {
          "name": "공지 삭제",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/notices/:noticeId",
            "urlPath": [{"key": "noticeId", "value": "여기에_noticeId_입력"}]
          }
        }
      ]
    },
    {
      "name": "3. Comment",
      "item": [
        {
          "name": "댓글 등록 (NOTICE)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"boardId\": \"{{boardId}}\",\n  \"boardType\": \"NOTICE\",\n  \"content\": \"테스트 댓글입니다.\"\n}"
            },
            "url": "{{baseUrl}}/api/comments"
          }
        },
        {
          "name": "댓글 등록 (COMPLAINT)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"boardId\": \"여기에_COMPLAINT_보드ID_입력\",\n  \"boardType\": \"COMPLAINT\",\n  \"content\": \"민원 게시판 댓글\"\n}"
            },
            "url": "{{baseUrl}}/api/comments"
          }
        },
        {
          "name": "댓글 수정",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"boardId\": \"{{boardId}}\",\n  \"boardType\": \"NOTICE\",\n  \"content\": \"수정된 댓글 내용\"\n}"
            },
            "url": "{{baseUrl}}/api/comments/:commentId",
            "urlPath": [{"key": "commentId", "value": "여기에_commentId_입력"}]
          }
        },
        {
          "name": "댓글 삭제",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/comments/:commentId",
            "urlPath": [{"key": "commentId", "value": "여기에_commentId_입력"}]
          }
        }
      ]
    }
  ]
}
