erDiagram
    USER {
        int id PK
        string profileImg
        string nickname
        int apartmentsId FK
        string name
        string email
        string phoneNumber
        string password
        role role
        register_status register_status
        timestamp createdAt
        timestamp updatedAt
        timestamp deletedAt
    }

    APARTMENT {
        int id PK
        string apt_name
        string apt_adress
        string office_number
        string startComplexNumber
        string endComplexNumber
        string startDongNumber
        string endDongNumber
        string startFloorNumber
        string endFloorNumber
        string startHoNumber
        string endHoNumber
        timestamp createdAt
        timestamp updatedAt
        timestamp deletedAt
    }

    REGISTER_REQ {
        int id PK
        int userId FK
        register_status register_status
        role role
        int dong
        int ho
        timestamp createdAt
    }

    RESIDENT {
        int id PK
        int userId FK
        int apt_id FK
        int dong
        int ho
        is_houseHold is_houseHold
        timestamp createdAt
        timestamp updatedAt
        timestamp deletedAt
    }

    BOARD {
        int id PK
        int authorId FK
        string title
        string content
        boardType boardType
        timestamp createdAt
        timestamp updatedAt
        timestamp deletedAt
    }

    COMPLAINT {
        int id PK
        int boardId FK
        int authorId FK
        status status
        is_public is_public
        timestamp createdAt
        timestamp updatedAt
        timestamp deletedAt
    }

    VOTE {
        int id PK
        int boardId FK
        int authorId FK
        status status
        string[] targetDong
        timestamp startDate
        timestamp endDate
        timestamp createdAt
        timestamp updatedAt
        timestamp deletedAt
    }

    NOTICE {
        int id PK
        int boardId FK
        int authorId FK
        timestamp startDate
        timestamp endDate
        boolean is_pinned
        noticeCategory category
        timestamp createdAt
        timestamp updatedAt
        timestamp deletedAt
    }

    COMMENT {
        int id PK
        int userId FK
        int boardId FK
        string content
        timestamp createdAt
        timestamp updatedAt
    }

    VOTE_OPTION {
        int id PK
        int voteId FK
        string option
        timestamp createdAt
        timestamp updatedAt
    }

    VOTE_PARTICIPATION {
        int id PK
        int residentId FK
        int voteId FK
        int voteOptionId FK
        timestamp createdAt
        timestamp updatedAt
    }

    NOTIFICATION {
        int id PK
        int userId FK
        int boardId FK
        int complaintId 
        int noticeId 
        int voteId 
        string message
        notificationType notificationType
        timestamp notificatedAt
        timestamp createdAt
    }

    %% ======================
    %% Relationships
    %% ======================

    APARTMENT ||--o{ USER : apartmentsId
    APARTMENT ||--o{ RESIDENT : apt_id

    USER ||--o{ REGISTER_REQ : userId
    USER ||--o{ RESIDENT : userId
    USER ||--o{ BOARD : authorId
    USER ||--o{ COMMENT : userId
    USER ||--o{ NOTIFICATION : userId

    BOARD ||--o{ COMMENT : boardId
    BOARD ||--|| COMPLAINT : boardId
    BOARD ||--|| VOTE : boardId
    BOARD ||--|| NOTICE : boardId
    BOARD ||--o{ NOTIFICATION : boardId

    VOTE ||--o{ VOTE_OPTION : voteId
    VOTE ||--o{ VOTE_PARTICIPATION : voteId

    RESIDENT ||--o{ VOTE_PARTICIPATION : residentId
    VOTE_OPTION ||--o{ VOTE_PARTICIPATION : voteOptionId